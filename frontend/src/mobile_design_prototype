        {[200, 140, 90].map((s, i) => (
          <div key={i} style={{
            position: "absolute", width: s, height: s, borderRadius: "50%",
            border: `${20 - i * 5}px solid rgba(255,255,255,${0.04 + i * 0.01})`,
            top: -s * 0.4, right: -s * 0.3,
          }} />
        ))}
        <div style={{
          width: 72, height: 72, borderRadius: 22, background: "rgba(255,255,255,0.12)",
          display: "flex", alignItems: "center", justifyContent: "center",
