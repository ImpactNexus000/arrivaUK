        <div style={{ flex: 1, overflow: "hidden", padding: "16px 20px 20px", display: "flex", flexDirection: "column", gap: 14 }}>
          <div>
            <div style={{ fontSize: 22, fontWeight: 700, color: ios.label, letterSpacing: -0.5, lineHeight: 1.25 }}>
              {steps[step].q}
            </div>
            <div style={{ fontSize: 14, color: ios.label3, marginTop: 5 }}>{steps[step].hint}</div>
          </div>
          <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
            {steps[step].opts.map((o, i) => (
              <button key={i} onClick={() => pick(i)} style={{
