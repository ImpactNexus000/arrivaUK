/* ─── Root App ─── */
export default function ArriveUK() {
  const [screen, setScreen] = useState("onboard");
  const [prevScreen, setPrev] = useState(null);

  const navigate = (to) => {
    setPrev(screen);
    setScreen(to);
  };

  const tabScreens = ["home", "checklist", "deals", "community", "budget"];
  const showTab = tabScreens.includes(screen);
  const showExtra = ["docs", "local"].includes(screen);

  const renderScreen = () => {
    switch (screen) {
      case "onboard":    return <OnboardScreen onDone={() => navigate("home")} />;
      case "home":       return <HomeScreen onNav={navigate} />;
      case "checklist":  return <ChecklistScreen />;
      case "deals":      return <DealsScreen />;
      case "budget":     return <BudgetScreen />;
      case "docs":       return <DocsScreen />;
      case "community":  return <CommunityScreen />;
      case "local":      return <LocalScreen />;
