      }}>
        {[
          ["onboard","1. Onboard"], ["home","2. Home"], ["checklist","3. Checklist"],
          ["deals","4. Deals"], ["budget","5. Budget"],
          ["docs","6. Docs"], ["community","7. Community"], ["local","8. Local"],
        ].map(([id, label]) => (
          <button key={id} onClick={() => navigate(id)} style={{
            padding: "7px 14px", borderRadius: 20, fontSize: 12, fontWeight: 500,
            border: "none", cursor: "pointer", transition: "all 0.15s",
            background: screen === id ? "#fff" : "rgba(255,255,255,0.12)",
            color: screen === id ? "#0A2342" : "rgba(255,255,255,0.7)",
          }}>{label}</button>
        ))}
      </div>

      {/* Phone shell */}
      <div style={{
        width: 375, height: 812,
        borderRadius: 54, overflow: "hidden", position: "relative",
        boxShadow: "0 50px 100px -20px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.05), inset 0 0 0 2px rgba(255,255,255,0.05)",
        background: ios.bg,
      }}>
        {/* Side buttons */}
        <div style={{ position: "absolute", left: -3, top: 130, width: 4, height: 32, background: "rgba(255,255,255,0.1)", borderRadius: "2px 0 0 2px" }} />
        <div style={{ position: "absolute", left: -3, top: 176, width: 4, height: 60, background: "rgba(255,255,255,0.1)", borderRadius: "2px 0 0 2px" }} />
        <div style={{ position: "absolute", left: -3, top: 248, width: 4, height: 60, background: "rgba(255,255,255,0.1)", borderRadius: "2px 0 0 2px" }} />
        <div style={{ position: "absolute", right: -3, top: 190, width: 4, height: 90, background: "rgba(255,255,255,0.1)", borderRadius: "0 2px 2px 0" }} />

        {/* Screen content */}
        <div style={{ display: "flex", flexDirection: "column", height: "100%", overflow: "hidden" }}>
          <div style={{ flex: 1, overflow: "hidden", display: "flex", flexDirection: "column" }}>
            {renderScreen()}
          </div>

          {/* Back button for sub-screens */}
          {showExtra && (
            <div style={{
              position: "absolute", top: 52, left: 16, zIndex: 100,
            }}>
              <button onClick={() => navigate("home")} style={{
                display: "flex", alignItems: "center", gap: 4,
                border: "none", background: "transparent", cursor: "pointer",
                color: ios.blue, fontSize: 16, fontWeight: 500, padding: 0,
              }}>
                <svg width="10" height="16" viewBox="0 0 10 16" fill="none">
                  <path d="M8 2L2 8L8 14" stroke={ios.blue} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                </svg>
                Back
              </button>
            </div>
          )}

          {showTab && (
            <>
              <TabBar active={screen} onNav={navigate} />
              <HomeIndicator />
            </>
          )}
          {screen === "onboard" && <HomeIndicator />}
        </div>
      </div>

      <div style={{ marginTop: 16, fontSize: 12, color: "rgba(255,255,255,0.25)", letterSpacing: 0.3 }}>
        ArriveUK · iOS Prototype
      </div>
    </div>
  );
}
