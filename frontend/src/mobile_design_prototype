/* ─── Screen 3: Checklist ─── */
function ChecklistScreen() {
  const [items, setItems] = useState([
    { id: 1, title: "Get a UK SIM card", hint: "Giffgaff, Smarty or Lebara — all student-friendly", badge: "done",   done: true,  group: "Essentials" },
    { id: 2, title: "Open a UK bank account", hint: "Monzo or Starling — no UK address needed", badge: "done",   done: true,  group: "Essentials" },
    { id: 3, title: "Apply for NI Number", hint: "Required before you can legally work in the UK", badge: "urgent", done: false, group: "Essentials" },
    { id: 4, title: "Register with a GP", hint: "Free NHS healthcare as an international student", badge: "soon",  done: false, group: "Admin" },
    { id: 5, title: "Get a 16-25 Railcard", hint: "Saves 1/3 on all UK train fares", badge: "soon",  done: false, group: "Admin" },
    { id: 6, title: "Register to vote", hint: "Builds UK credit history too", badge: null,  done: false, group: "Admin" },
  ]);

  const toggle = (id) => setItems(items.map(i => i.id === id ? { ...i, done: !i.done } : i));
  const done = items.filter(i => i.done).length;
  const pct = Math.round(done / items.length * 100);
  const groups = ["Essentials", "Admin"];

  const badgeColor = { urgent: "red", soon: "orange", done: "green" };

  return (
    <div style={{ display: "flex", flexDirection: "column", height: "100%", background: ios.bg }}>
      <div style={{ background: ios.navy, flexShrink: 0 }}>
        <StatusBar />
        <div style={{ padding: "4px 20px 20px" }}>
          <div style={{ fontSize: 26, fontWeight: 700, color: "#fff", letterSpacing: -0.6 }}>Arrival Checklist</div>
          <div style={{ fontSize: 13, color: "rgba(255,255,255,0.5)", marginTop: 3 }}>
            {done} of {items.length} completed
          </div>
          {/* Progress bar */}
          <div style={{ marginTop: 14, height: 6, background: "rgba(255,255,255,0.15)", borderRadius: 6, overflow: "hidden" }}>
            <div style={{
              height: "100%", width: `${pct}%`, borderRadius: 6,
              background: "linear-gradient(90deg, #34C759, #30D158)",
              transition: "width 0.4s ease",
            }} />
          </div>
          <div style={{ fontSize: 11, color: "rgba(255,255,255,0.4)", marginTop: 5 }}>{pct}% complete</div>
        </div>
      </div>

      <div style={{ flex: 1, overflowY: "auto", padding: "16px" }}>
        {groups.map(group => (
          <div key={group} style={{ marginBottom: 8 }}>
            <div style={{ fontSize: 13, fontWeight: 600, color: ios.label3, letterSpacing: 0.3, textTransform: "uppercase", padding: "8px 4px 8px" }}>
              {group}
            </div>
            <div style={{
              background: ios.bg2, borderRadius: 16, overflow: "hidden",
              border: `0.5px solid ${ios.sep}`,
            }}>
              {items.filter(i => i.group === group).map((item, idx, arr) => (
                <div key={item.id}>
                  <div onClick={() => toggle(item.id)} style={{
                    display: "flex", alignItems: "center", gap: 12,
                    padding: "14px 16px", cursor: "pointer",
                    background: item.done ? "rgba(52,199,89,0.06)" : ios.bg2,
                    transition: "background 0.15s",
                  }}>
                    {/* Checkbox */}
                    <div style={{
                      width: 24, height: 24, borderRadius: 12, flexShrink: 0,
                      border: item.done ? "none" : `2px solid ${ios.label4}`,
                      background: item.done ? ios.green : "transparent",
                      display: "flex", alignItems: "center", justifyContent: "center",
                      transition: "all 0.2s",
                    }}>
                      {item.done && <svg width="13" height="10" viewBox="0 0 13 10" fill="none">
                        <path d="M1.5 5L5 8.5L11.5 1.5" stroke="white" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                      </svg>}
                    </div>
                    <div style={{ flex: 1, minWidth: 0 }}>
                      <div style={{
                        fontSize: 15, fontWeight: 500, color: item.done ? ios.label3 : ios.label,
                        textDecoration: item.done ? "line-through" : "none",
                        textDecorationColor: ios.label4,
                        letterSpacing: -0.2,
                      }}>{item.title}</div>
                      <div style={{ fontSize: 12, color: ios.label4, marginTop: 2, lineHeight: 1.4 }}>{item.hint}</div>
                    </div>
                    {item.badge && !item.done && (
                      <Badge label={item.badge === "urgent" ? "Urgent" : "Soon"} color={badgeColor[item.badge]} />
                    )}
                    {item.done && <Badge label="Done" color="green" />}
                  </div>
                  {idx < arr.length - 1 && <div style={{ height: "0.5px", background: ios.sep, marginLeft: 52 }} />}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

